# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Inbox that receives contact-form submissions
CONTACT_EMAIL=veronique.guyomard@revesdevoyages.fr

# Sender shown on contact/devis emails. Defaults to the verified
# "Rêves de Voyages <contact@revesdevoyages.fr>"; override only if needed.
# CONTACT_FROM=Rêves de Voyages <contact@revesdevoyages.fr>

# Canonical site URL — the WEBSITE domain (.com), used for metadata, sitemap, JSON-LD.
# Note: the email domain is .fr (see CONTACT_EMAIL) — site and email domains differ on purpose.
NEXT_PUBLIC_SITE_URL=https://www.revesdevoyages.com

# Google Search Console meta-tag verification token (the value of the
# content="..." attribute Google gives you). Optional — leave unset if you
# verify ownership via DNS TXT at Gandi instead.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
